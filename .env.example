# OwnPaper environment example.
# Copy this file to .env for Docker/local deployments and replace placeholders.
# Do not commit real secrets.

DJANGO_SETTINGS_MODULE=config.settings.production
COMPOSE_PROJECT_NAME=tudo_e_comportamento
DJANGO_SECRET_KEY=change-me-generate-a-long-random-secret
DJANGO_DEBUG=false
OWNPAPER_HTTP_PORT=8000

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_WAGTAIL_SITE_NAME=OwnPaper
DJANGO_WAGTAILADMIN_BASE_URL=http://localhost:8000

DJANGO_LANGUAGE_CODE=pt-br
DJANGO_TIME_ZONE=America/Sao_Paulo
DJANGO_DEFAULT_AUTO_FIELD=django.db.models.AutoField

DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=ownpaper
DATABASE_USER=ownpaper
DATABASE_PASSWORD=change-me
DATABASE_HOST=db
DATABASE_PORT=5432

DJANGO_STATIC_URL=/static/
DJANGO_STATIC_ROOT=/app/static
OWNPAPER_STATIC_VOLUME=/var/www/ownpaper/static
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=/app/media
OWNPAPER_MEDIA_VOLUME=/var/www/ownpaper/media

DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_USE_SSL=false
DJANGO_DEFAULT_FROM_EMAIL=no-reply@localhost

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Enable only after HTTPS is correctly routed to this app.
DJANGO_SECURE_PROXY_SSL_HEADER=false
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false

# Container startup behavior.
OWNPAPER_WAIT_FOR_DB=true
OWNPAPER_RUN_MIGRATIONS=true
OWNPAPER_BOOTSTRAP=false
OWNPAPER_BOOTSTRAP_PAGES=true
OWNPAPER_BOOTSTRAP_FORCE=false
OWNPAPER_COLLECTSTATIC=true

# Initial setup
OWNPAPER_SITE_NAME=OwnPaper
OWNPAPER_SITE_HOSTNAME=localhost
OWNPAPER_SITE_PORT=80
OWNPAPER_HOME_TITLE=Home
OWNPAPER_SITE_DESCRIPTION=OwnPaper editorial CMS.
OWNPAPER_CONTACT_EMAIL=
OWNPAPER_FOOTER_TEXT=
OWNPAPER_COPYRIGHT_TEXT=
OWNPAPER_INDEXER_LABEL=Indexador
OWNPAPER_ADMIN_USERNAME=
OWNPAPER_ADMIN_EMAIL=
OWNPAPER_ADMIN_PASSWORD=
OWNPAPER_ADMIN_RESET_PASSWORD=false
