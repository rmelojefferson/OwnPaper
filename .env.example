# OwnPaper local/default environment example.
# Copy this file to .env for Docker/local deployments and replace placeholders.
# For HTTPS production preset, use `.env.production.example`.
# Do not commit real secrets.

DJANGO_SETTINGS_MODULE=config.settings.production
COMPOSE_PROJECT_NAME=ownpaper
DJANGO_SECRET_KEY=change-me-generate-a-long-random-secret
DJANGO_DEBUG=false
OWNPAPER_HTTP_PORT=8000

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_WAGTAIL_SITE_NAME=OwnPaper
DJANGO_WAGTAILADMIN_BASE_URL=http://localhost:8000
OWNPAPER_PUBLIC_BASE_URL=http://localhost:8000

DJANGO_LANGUAGE_CODE=pt-br
DJANGO_TIME_ZONE=America/Sao_Paulo
DJANGO_DEFAULT_AUTO_FIELD=django.db.models.AutoField

DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=ownpaper
DATABASE_USER=ownpaper
DATABASE_PASSWORD=change-me
DATABASE_HOST=db
DATABASE_PORT=5432

DJANGO_STATIC_URL=/static/
DJANGO_STATIC_ROOT=/app/static
OWNPAPER_STATIC_VOLUME=/var/www/ownpaper/static
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=/app/media
OWNPAPER_MEDIA_VOLUME=/var/www/ownpaper/media
OWNPAPER_SERVE_PUBLIC_MEDIA=true
OWNPAPER_PRIVATE_MEDIA_VOLUME=ownpaper_private_media
OWNPAPER_BACKUP_VOLUME=ownpaper_backups

# Upload security. Enabled by default in Docker via bundled ClamAV.
OWNPAPER_CLAMAV_ENABLED=true
OWNPAPER_CLAMAV_HOST=clamav
OWNPAPER_CLAMAV_PORT=3310
OWNPAPER_CLAMAV_TIMEOUT=30
OWNPAPER_VIDEO_MAX_MB=500

DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_USE_SSL=false
DJANGO_DEFAULT_FROM_EMAIL=no-reply@localhost

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Turnstile is auto-enabled when both keys above are set.

# External integrations.
# For new installations, prefer keeping OAuth/Shlink credentials here instead of the admin DB.
# The application reads these variables first and only falls back to panel values when they are empty.
# When using the bundled optional Shlink profile with a base path, point
# OWNPAPER_SHLINK_BASE_URL to http://shlink:8080/<base-path>
# and keep OWNPAPER_SHLINK_API_KEY equal to SHLINK_INITIAL_API_KEY.
OWNPAPER_SHLINK_BASE_URL=
OWNPAPER_SHLINK_API_KEY=
OWNPAPER_OAUTH_ORCID_CLIENT_ID=
OWNPAPER_OAUTH_ORCID_CLIENT_SECRET=
OWNPAPER_OAUTH_GITHUB_CLIENT_ID=
OWNPAPER_OAUTH_GITHUB_CLIENT_SECRET=
OWNPAPER_OAUTH_GOOGLE_CLIENT_ID=
OWNPAPER_OAUTH_GOOGLE_CLIENT_SECRET=
OWNPAPER_OAUTH_CODEBERG_CLIENT_ID=
OWNPAPER_OAUTH_CODEBERG_CLIENT_SECRET=
OWNPAPER_OAUTH_CODEBERG_BASE_URL=https://codeberg.org

# Optional bundled Shlink service (docker compose --profile shlink up -d)
# This creates a dedicated Shlink + PostgreSQL stack for short links.
# You still need to route SHLINK_DEFAULT_DOMAIN or SHLINK_BASE_PATH to the Shlink container in your reverse proxy.
SHLINK_HTTP_PORT=18081
SHLINK_DEFAULT_DOMAIN=s.localhost
SHLINK_BASE_PATH=
SHLINK_IS_HTTPS_ENABLED=false
SHLINK_GEOLITE_LICENSE_KEY=
SHLINK_SKIP_INITIAL_GEOLITE_DOWNLOAD=true
SHLINK_INITIAL_API_KEY=
SHLINK_DB_NAME=shlink
SHLINK_DB_USER=shlink
SHLINK_DB_PASSWORD=change-me

# Public form protection and validation
OWNPAPER_FORM_RATE_LIMIT_WINDOW_SECONDS=600
OWNPAPER_FORM_RATE_LIMIT_MAX_ATTEMPTS_IP=5
OWNPAPER_FORM_RATE_LIMIT_MAX_ATTEMPTS_EMAIL=3
OWNPAPER_FORM_RATE_LIMIT_BACKOFF_BASE_SECONDS=120
OWNPAPER_FORM_RATE_LIMIT_BACKOFF_MAX_SECONDS=3600
OWNPAPER_CONTACT_MAX_NOME_LENGTH=120
OWNPAPER_CONTACT_MAX_MENSAGEM_LENGTH=5000
OWNPAPER_NEWSLETTER_MAX_EMAIL_LENGTH=254
OWNPAPER_CONTACT_MESSAGES_RETENTION_DAYS=365
OWNPAPER_NEWSLETTER_EXCLUSAO_GRACE_DAYS=3
OWNPAPER_USER_INVITE_EXPIRY_DAYS=7
# IPs ou redes CIDR ignorados nas visualizações e estatísticas internas. Ex.: 203.0.113.10,192.168.0.0/24
OWNPAPER_ANALYTICS_EXCLUDED_IPS=
# Token opcional para registrar automaticamente o IP público dinâmico de uma rede confiável.
OWNPAPER_ANALYTICS_DYNAMIC_EXCLUDE_TOKEN=
OWNPAPER_ANALYTICS_DYNAMIC_EXCLUDE_TTL_HOURS=72
OWNPAPER_ANALYTICS_BLOCK_BOTS=true
# Regex separados por virgula para bloquear user-agents adicionais nas estatisticas internas.
OWNPAPER_ANALYTICS_BLOCKED_USER_AGENT_PATTERNS=
OWNPAPER_ANALYTICS_FINGERPRINT_THROTTLE_ENABLED=true
OWNPAPER_ANALYTICS_FINGERPRINT_THROTTLE_SECONDS=21600
OWNPAPER_ANALYTICS_FINGERPRINT_THROTTLE_MAX_HITS=5
OWNPAPER_FORMS_SECURITY_LOG_LEVEL=INFO

# Enable only after HTTPS is correctly routed to this app.
DJANGO_SECURE_PROXY_SSL_HEADER=false
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_SECURE_CONTENT_TYPE_NOSNIFF=true
DJANGO_SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
DJANGO_X_FRAME_OPTIONS=DENY

# Container startup behavior.
OWNPAPER_WAIT_FOR_DB=true
OWNPAPER_RUN_MIGRATIONS=true
OWNPAPER_BOOTSTRAP=false
OWNPAPER_BOOTSTRAP_PAGES=true
OWNPAPER_BOOTSTRAP_FORCE=false
OWNPAPER_PROCESS_PRIVACY_EXCLUSIONS=true
OWNPAPER_CLEAN_PRIVACY_EXPORTS=true
OWNPAPER_PRIVACY_EXPORT_RETENTION_DAYS=7
OWNPAPER_COLLECTSTATIC=true
OWNPAPER_PRECOMPUTE_SEARCH_CACHE=false
OWNPAPER_PRECOMPUTE_SEARCH_CACHE_LIMIT=200
OWNPAPER_SCHEDULER_ENABLED=true
OWNPAPER_SCHEDULER_INITIAL_DELAY_SECONDS=120
OWNPAPER_SCHEDULER_INTERVAL_SECONDS=3600

# Full-system backups. WebDAV credentials are backend-only and must be set here or in the deployment environment.
OWNPAPER_BACKUP_ENABLED=true
OWNPAPER_BACKUP_INTERVAL_HOURS=168
OWNPAPER_BACKUP_RETENTION_DAYS=30
OWNPAPER_BACKUP_INCLUDE_MEDIA=true
OWNPAPER_BACKUP_INCLUDE_PRIVATE_MEDIA=true
OWNPAPER_BACKUP_EXTERNAL_BACKEND=local
OWNPAPER_BACKUP_WEBDAV_URL=
OWNPAPER_BACKUP_WEBDAV_USERNAME=
OWNPAPER_BACKUP_WEBDAV_PASSWORD=

# Initial setup
OWNPAPER_SITE_NAME=OwnPaper
OWNPAPER_SITE_HOSTNAME=localhost
OWNPAPER_SITE_PORT=80
OWNPAPER_HOME_TITLE=Home
OWNPAPER_SITE_DESCRIPTION=OwnPaper editorial CMS.
OWNPAPER_CONTACT_EMAIL=
OWNPAPER_FOOTER_TEXT=
OWNPAPER_COPYRIGHT_TEXT=
OWNPAPER_INDEXER_LABEL=Indexador
OWNPAPER_ADMIN_USERNAME=
OWNPAPER_ADMIN_EMAIL=
OWNPAPER_ADMIN_PASSWORD=
OWNPAPER_ADMIN_RESET_PASSWORD=false
